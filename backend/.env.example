# HSE Enterprise Platform — Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control
#
# SECRETS MANAGEMENT (Production)
# -------------------------------
# This platform supports three methods for managing secrets, in order of precedence:
#
# 1. Docker Secrets (recommended for production containers)
#    - Place secret files in ./secrets/ directory
#    - Files: postgres_password.txt, secret_key.txt, smtp_password.txt, etc.
#    - The application will automatically read from /run/secrets/<name> in containers
#
# 2. Azure Key Vault (recommended for Azure production deployments)
#    - Set AZURE_KEY_VAULT_URL environment variable
#    - The application will fetch secrets from Key Vault
#
# 3. Environment Variables (development only)
#    - Set variables directly in .env file
#    - DO NOT use in production
#
# For production, use Docker secrets or Azure Key Vault.
# See backend/secrets/ directory for secret file templates.

# =============================================
# APPLICATION
# =============================================
APP_NAME=HSE Enterprise Platform
APP_VERSION=1.0.0
DEBUG=false
# SECRET_KEY can be set via Docker secret (secret_key.txt) or Azure Key Vault
SECRET_KEY=change-me-in-production-use-strong-secret-at-least-32-chars

# =============================================
# DATABASE
# =============================================
# DATABASE_URL can be set via Docker secret or Azure Key Vault
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/hse_edw
DATABASE_ECHO=false

# =============================================
# REDIS
# =============================================
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# =============================================
# JWT / AUTH
# =============================================
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================
# CORS
# =============================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://localhost:8000","http://localhost:5173"]
CORS_ALLOW_CREDENTIALS=true

# =============================================
# RATE LIMITING
# =============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# =============================================
# ALERT ENGINE
# =============================================
ALERT_EMAIL_ENABLED=true
ALERT_TELEGRAM_ENABLED=false
ALERT_WHATSAPP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD can be set via Docker secret (smtp_password.txt) or Azure Key Vault
SMTP_PASSWORD=your-app-password
ALERT_FROM_EMAIL=hse-alerts@company.com
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================
# MONITORING
# =============================================
# GRAFANA_PASSWORD can be set via Docker secret (grafana_password.txt)
GRAFANA_PASSWORD=admin123
# INFLUXDB_PASSWORD can be set via Docker secret (influxdb_password.txt)
INFLUXDB_PASSWORD=admin123
# POSTGRES_PASSWORD can be set via Docker secret (postgres_password.txt)
POSTGRES_PASSWORD=postgres123
PGADMIN_EMAIL=admin@hse.local
# PGADMIN_PASSWORD can be set via Docker secret (pgadmin_password.txt)
PGADMIN_PASSWORD=admin123

# =============================================
# AZURE KEY VAULT (optional)
# =============================================
# AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net/

# =============================================
# FEATURE FLAGS
# =============================================
ENABLE_PREDICTIVE_ANALYTICS=false
ENABLE_WEBSOCKET=true
ENABLE_CACHING=true

# =============================================
# AI / EMBEDDINGS
# =============================================
# WARNING: Mock embeddings MUST NOT be used in production.
# Set OPENAI_API_KEY and keep ENABLE_MOCK_EMBEDDINGS=false in production.
ENABLE_MOCK_EMBEDDINGS=false
OPENAI_API_KEY=

# =============================================
# SECURITY / RBAC
# =============================================
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SYMBOL=true
PASSWORD_EXPIRE_DAYS=90
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15
SESSION_IDLE_TIMEOUT_MINUTES=30
SESSION_ABSOLUTE_TIMEOUT_HOURS=12
REQUIRE_PASSWORD_CHANGE_ON_FIRST_LOGIN=true
