@startuml Trust Boundary Diagram
!theme plain

title Enterprise HSE Platform — Trust Boundary Diagram

' ZONES
package "UNTRUSTED NETWORK (Internet)" {
    [External Users\nBrowsers, Mobile] as ext_users
    [External Integrations\nSAP, HRIS, SCADA, IoT] as ext_systems
}

package "DMZ (Low Trust)" {
    [Nginx Reverse Proxy] as nginx
    [WAF (Optional)] as waf
}

package "APPLICATION ZONE (Medium Trust)" {
    [FastAPI Backend] as api
    [Celery Workers] as celery
    [PgAdmin] as pgadmin
}

package "DATA ZONE (High Trust)" {
    [PostgreSQL Primary] as pg_primary
    [PostgreSQL Replica] as pg_replica
    [Redis Cache] as redis
    [pgvector] as vector
}

package "MONITORING ZONE (Medium Trust)" {
    [Prometheus] as prometheus
    [Grafana] as grafana
    [Loki] as loki
    [Tempo] as tempo
    [OTEL Collector] as otel
}

package "MANAGEMENT ZONE (High Trust)" {
    [Backup Service] as backup
    [CI/CD Runner] as cicd
    [Secrets Manager] as secrets
}

' TRUST BOUNDARIES
boundary "TB1: Internet → DMZ" as tb1
boundary "TB2: DMZ → Application" as tb2
boundary "TB3: Application → Data" as tb3
boundary "TB4: Application ↔ Monitoring" as tb4
boundary "TB5: Management ↔ All Zones" as tb5

' CROSSINGS
ext_users -- tb1 : "HTTPS:443\nTLS 1.3"
ext_systems -- tb1 : "HTTPS:443\nTLS 1.3"

tb1 -- nginx : "Allow: 443"
tb1 -- waf : "Allow: 443"

nginx -- tb2 : "Allow: 8000\nInternal only"
waf -- tb2 : "Allow: 8000\nInternal only"

tb2 -- api : "Allow: 8000\nNo external access"
tb2 -- pgadmin : "Allow: 5050\nInternal only"

api -- tb3 : "Allow: 5432, 6379\nSSL required"
celery -- tb3 : "Allow: 5432, 6379\nSSL required"
pgadmin -- tb3 : "Allow: 5432\nSSL required"
backup -- tb3 : "Allow: 5432\nSSL required"

api -- tb4 : "Allow: 4317, 9090\nInternal only"
celery -- tb4 : "Allow: 4317, 9090\nInternal only"

tb4 -- otel : "Allow: 4317\ngRPC internal"
tb4 -- prometheus : "Allow: 9090\nHTTP internal"

prometheus -- pg_primary : "Allow: 9187\nMetrics endpoint"
prometheus -- redis : "Allow: 9121\nMetrics endpoint"

grafana -- prometheus : "Allow: 9090\nQuery metrics"
grafana -- loki : "Allow: 3100\nQuery logs"
grafana -- tempo : "Allow: 3200\nQuery traces"

cicd -- tb5 : "SSH:22\nJump host only"
secrets -- tb5 : "Allow: 443\nAPI access"

' SECURITY CONTROLS
note bottom of tb1
  **Controls:**
  - TLS 1.3 termination
  - DDoS protection
  - IP whitelisting (optional)
  - WAF rules (OWASP Top 10)
  - Rate limiting
end note

note bottom of tb2
  **Controls:**
  - No direct internet access
  - mTLS between services (optional)
  - Network policies (Kubernetes)
  - Service mesh (future)
end note

note bottom of tb3
  **Controls:**
  - PostgreSQL SSL/TLS required
  - Redis no external access
  - Database firewall rules
  - Encryption at rest (AES-256)
  - Column-level encryption for PII
end note

note bottom of tb4
  **Controls:**
  - Telemetry data internal only
  - No PII in logs/metrics
  - Access control on Grafana
  - Audit logging for queries
end note

note bottom of tb5
  **Controls:**
  - SSH key authentication only
  - Bastion host / jump server
  - VPN required for remote access
  - Just-In-Time access (future)
  - Session recording (future)
end note

' DATA CLASSIFICATION
legend right
  | Zone | Trust Level | Data Classification | Access |
  | Internet | Untrusted | Public | Authenticated |
  | DMZ | Low | Public/Internal | TLS + WAF |
  | Application | Medium | Internal/Confidential | RBAC + mTLS |
  | Data | High | Confidential/Restricted | Encryption + Audit |
  | Monitoring | Medium | Internal | RBAC |
  | Management | High | Restricted | VPN + MFA |
endlegend

@enduml
